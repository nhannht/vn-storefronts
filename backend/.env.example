# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real secrets.

# CORS allow-lists (dev defaults for local storefronts + admin dashboard)
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com

# Postgres (local dev, no docker). Matches brew postgresql@17 on localhost.
# Use your local Postgres role in place of USER.
DATABASE_URL=postgres://USER@localhost:5432/vn_storefronts

# Redis (local dev, brew redis on localhost). Used by the event bus and
# workflow engine modules.
REDIS_URL=redis://localhost:6379

# Secrets. Generate strong random values for any non-local environment.
JWT_SECRET=change-me
COOKIE_SECRET=change-me

# Admin multi-factor encryption key. 32-byte hex: openssl rand -hex 32
AUTH_MFA_ENCRYPTION_KEY=change-me

# Onboarding flow shown by the admin dashboard.
MEDUSA_ADMIN_ONBOARDING_TYPE=default
