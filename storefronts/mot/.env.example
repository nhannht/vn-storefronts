# Copy to .env.local and fill in the current publishable key.
# .env.local is gitignored - never commit a real key.

# Medusa backend base URL (local dev).
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# mot publishable API key. Scopes all requests to the mot channel.
# Get the current value from the backend: seed-foundation prints it, or
#   psql: SELECT ak.token FROM api_key ak
#     JOIN publishable_api_key_sales_channel pkc ON pkc.publishable_key_id = ak.id
#     JOIN sales_channel sc ON sc.id = pkc.sales_channel_id
#     WHERE sc.name = 'mot';
# Keys REGENERATE on every reseed - never commit a real value.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_me
